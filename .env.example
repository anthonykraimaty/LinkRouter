# Copy to .env and fill in real values. .env is gitignored.

# --- Database ---
POSTGRES_DB=routesmapper
POSTGRES_USER=routesmapper
POSTGRES_PASSWORD=changeme

# --- Auth ---
JWT_SECRET=super-secret-change-me-in-production

# --- Frontend build-time API base (nginx proxies /api → backend) ---
VITE_API_URL=/api

# --- Host port mapping (host:container). nginx is the public entry point. ---
APP_PORT=5005          # nginx -> public site
BACKEND_PORT=5006      # backend direct (debug)
POSTGRES_PORT=5436     # postgres direct (admin tools)
FRONTEND_PORT=5007     # frontend container direct (internal)
